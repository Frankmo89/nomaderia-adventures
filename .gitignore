# Environment variables — never commit secrets
.env
.env.local
.env.*.local

# Supabase Edge Function local secrets — never commit
supabase/functions/.env
supabase/functions/**/.env
supabase/.env

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Non-npm lockfiles — Cloudflare Pages uses npm install
bun.lockb
yarn.lock

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Claude Code temp files
tmpclaude-*
nul
